# www -> apex must be configured as a Cloudflare Bulk Redirect.
# Cloudflare Pages _redirects does not support domain-level redirects.

# Legacy type PNG URLs now point at the compressed WebP assets.
/types/:image.png /types/:image.webp 301

# Root serves English content (rewrite, not redirect — SEO friendly)
/ /en 200

# Unprefixed English paths rewrite to /en/* so /blog, /faq, /compat etc. work.
# We explicitly list each route (no /* wildcard) because Cloudflare Pages does
# not reliably honor static-file priority over wildcard rewrites — a wildcard
# would intercept locale-prefixed paths like /ko, /zh/about as well.
/about /en/about 200
/blog /en/blog 200
/blog/* /en/blog/:splat 200
/compat /en/compat 200
/compat/* /en/compat/:splat 200
/faq /en/faq 200
/privacy-policy /en/privacy-policy 200
/result/* /en/result/:splat 200
/terms /en/terms 200
/test /en/test 200
/type/* /en/type/:splat 200
/types /en/types 200
